# ── .dockerignore ─────────────────────────────────────────────────────────
# Keeps the Docker image lean by excluding dev files.

# Secrets — NEVER copy into image
.env
*.session
*.session-journal

# Data files — mounted as volume at runtime
*.json
data/

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Dev tools
.git/
.gitignore
*.md
screenshots/
.vscode/
.idea/

# OS junk
.DS_Store
Thumbs.db
