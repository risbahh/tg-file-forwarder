# ── REQUIRED ──────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Run python session_gen.py to generate this — paste the output here
SESSION_STRING=BQA...longstring...

# Your private index channel ID (negative number, e.g. -1001234567890)
DEST_CHANNEL=-1001234567890

# Comma-separated list of source groups/channels to watch at startup
# Can be usernames or numeric IDs. Also add via /addchat at runtime.
SOURCE_CHATS=CineAlliance,MoviesHDHub,-100987654321

# Your Telegram user ID (get from @userinfobot) — can use all commands
# Comma-separated for multiple admins: 123456789,987654321
ADMINS=123456789

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Seconds to wait between each forward (increase if FloodWait errors appear)
DELAY=3

# Extra seconds added on top of Telegram's FloodWait value
FLOOD_EXTRA=5

# Max retries before skipping a file
MAX_RETRIES=5

# Messages fetched per API call in bulk_dump.py
BATCH_SIZE=200

# File types to forward (comma-separated: document, video, audio, photo)
ALLOWED_TYPES=document,video

# Get startup notifications, /addchat confirmations, and daily stats here
LOG_CHANNEL=-1009876543210

# ── FILE PATHS (usually leave as defaults) ─────────────────────────────────
# Progress tracker for bulk_dump.py — lists forwarded message IDs
TRACKER_FILE=forwarded.json

# Dynamic source chat list — updated by /addchat command
CHATS_DB_FILE=chats.json

# Bot-group mapping — updated by /setbot command (bot_capture.py)
BOTS_DB_FILE=bots.json
