# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Run python session_gen.py to generate this — paste the output here
SESSION_STRING=BQA...longstring...

# Your private index channel ID (negative number, e.g. -1001234567890)
# This is the channel your auto-filter bot reads from
DEST_CHANNEL=-1001234567890

# Comma-separated list of source groups/channels to watch and dump
# Can be usernames (@CineAlliance) or numeric IDs (-100987654321)
SOURCE_CHATS=CineAlliance,MoviesHDHub,-100987654321

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Seconds to wait between each forward (increase if getting FloodWait)
DELAY=3

# Extra seconds added on top of Telegram's FloodWait value
FLOOD_EXTRA=5

# Max retries before skipping a file
MAX_RETRIES=5

# Messages fetched per API call in bulk dump mode
BATCH_SIZE=200

# File types to forward (comma-separated: document, video, audio, photo)
ALLOWED_TYPES=document,video

# Optional: send dump summary here when bulk_dump.py finishes
LOG_CHANNEL=-1009876543210

# File to track progress for bulk_dump.py (resume support)
TRACKER_FILE=forwarded.json
