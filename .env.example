# ── REQUIRED ───────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Generate once locally: python session_gen.py — paste the output here
SESSION_STRING=BQA...longstring...

# Your primary index channel (default/fallback destination)
DEST_CHANNEL=-1001234567890

# Comma-separated source groups. Also add at runtime via /addchat
SOURCE_CHATS=CineAlliance,MoviesHDHub,-100987654321

# Your Telegram user ID (from @userinfobot). Comma-separated for multiple admins.
ADMINS=123456789

# ── MULTI-DESTINATION ROUTING ──────────────────────────────────────────────────
# Leave blank to send everything to DEST_CHANNEL
DEST_MOVIES=-1001111111111   # standalone movies go here
DEST_SERIES=-1002222222222   # S01E01/Season/Episode pattern → here
DEST_SOUTH=-1003333333333    # Tamil/Telugu/Malayalam/Hindi Dubbed → here

# ── MULTI-ACCOUNT (multi_forwarder.py) ────────────────────────────────────────
# When Account 1 hits FloodWait, Account 2 takes over, then Account 3
SESSION_STRING_2=BQA...account2...
SESSION_STRING_3=BQA...account3...

# ── RATE & RETRY ───────────────────────────────────────────────────────────────
DELAY=3           # seconds between each forward (increase if FloodWait frequent)
FLOOD_EXTRA=5     # extra seconds added on top of Telegram's FloodWait value
MAX_RETRIES=5     # retries before giving up on a file

# ── CAPTION CLEANING ───────────────────────────────────────────────────────────
# Strip @watermarks, t.me/ links, [TamilMV] tags from captions before forwarding
CLEAN_CAPTIONS=true

# ── BULK DUMP ──────────────────────────────────────────────────────────────────
BATCH_SIZE=200    # messages fetched per API call in bulk_dump.py

# ── FILE FILTERING ─────────────────────────────────────────────────────────────
ALLOWED_TYPES=document,video   # comma-separated: document, video, audio, photo

# ── NOTIFICATIONS ──────────────────────────────────────────────────────────────
LOG_CHANNEL=-1009876543210    # startup/addchat notifications sent here

# ── FILE PATHS (usually leave as defaults) ─────────────────────────────────────
TRACKER_FILE=forwarded.json   # bulk_dump.py progress (resume after crash)
CHATS_DB_FILE=chats.json      # dynamic source list (/addchat)
BOTS_DB_FILE=bots.json        # bot-group mapping (/setbot in bot_capture.py)
SEEN_DB_FILE=seen.json        # duplicate detection (file_unique_id set)
ROUTING_FILE=routing.json     # per-source routing overrides (/route)
